<Window x:Class="RenPyAutoTranslate.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:RenPyAutoTranslate.Wpf.Converters"
        mc:Ignorable="d"
        Title="Ren'Py — Translate TL folder"
        Height="680" Width="720" MinWidth="560" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource WindowForegroundBrush}">
  <Window.Resources>
    <conv:InvertBoolConverter x:Key="InvertBool" />
  </Window.Resources>
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <!-- ~80% form (scrolls), ~20% log; top scrolls when the window is short. -->
      <RowDefinition Height="4*" MinHeight="220" />
      <RowDefinition Height="1*" MinHeight="100" />
    </Grid.RowDefinitions>

    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel>
        <TextBlock Text="Source" FontWeight="SemiBold" Margin="0,0,0,8" />
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Source TL folder" VerticalAlignment="Center" Width="140" Margin="0,0,12,0" />
          <TextBox Grid.Column="1" Text="{Binding SourceTlPath, Mode=OneWay}" IsReadOnly="True" VerticalAlignment="Center" Margin="0,0,8,0" />
          <Button Grid.Column="2" Content="Browse…" Command="{Binding BrowseTlCommand}" Padding="12,6" MinWidth="88"
                  IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}" />
        </Grid>
        <TextBlock Text="Detected game" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="{Binding DetectedGame}" Margin="0,0,0,4" />
        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextMutedBrush}"
                   Text="(from …/name/game/tl) → output under tool folder" Margin="0,0,0,12" />
        <TextBlock Text="Output TL (write)" FontWeight="SemiBold" Margin="0,0,0,4" />
        <TextBlock Text="{Binding OutputPreview}" TextWrapping="Wrap" Margin="0,0,0,12" />

        <TextBlock Text="Translation" FontWeight="SemiBold" Margin="0,8,0,8" />
        <TextBlock Text="Translate into (check one or more; runs in order listed)" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,6" />
        <Border BorderBrush="{DynamicResource GroupBoxBorderBrush}" BorderThickness="1" CornerRadius="2" MaxHeight="200" Padding="4,6" Margin="0,0,0,8">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding LanguageOptions}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <CheckBox Margin="0,2" Content="{Binding FolderName}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                            IsEnabled="{Binding DataContext.IsBusy, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InvertBool}}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>
        <Grid Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Source language (ISO)" VerticalAlignment="Center" Width="140" Margin="0,0,12,0" />
          <TextBox Grid.Column="1" Text="{Binding SourceIso, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}" />
          <TextBlock Grid.Column="2" Text="common.rpy uses en → target" VerticalAlignment="Center" Margin="12,0,0,0"
                     Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
        </Grid>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Workers" VerticalAlignment="Center" Width="140" Margin="0,0,12,0" />
          <TextBox Grid.Column="1" Text="{Binding Workers, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}" />
          <TextBlock Grid.Column="2" Text="Request pacing adjusts if the server throttles (HTTP 429)." VerticalAlignment="Center" Margin="12,0,0,0"
                     Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
        </Grid>

        <TextBlock Text="Appearance" FontWeight="SemiBold" Margin="0,8,0,8" />
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="200" />
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Theme" VerticalAlignment="Center" Width="140" Margin="0,0,12,0" />
          <ComboBox Grid.Column="1" ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding UiTheme, Mode=TwoWay}" MinHeight="28" />
        </Grid>

        <TextBlock Text="Run" FontWeight="SemiBold" Margin="0,8,0,8" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
          <Button Content="Translate" Command="{Binding TranslateCommand}" Padding="16,8" MinWidth="100" Margin="0,0,8,0"
                  IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}" />
          <Button Content="Resume" Command="{Binding ResumeCommand}" Padding="16,8" MinWidth="88" Margin="0,0,8,0"
                  IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}" />
          <Button Content="Cancel" Command="{Binding CancelRunCommand}" Padding="16,8" MinWidth="88" Margin="0,0,8,0"
                  IsEnabled="{Binding IsBusy}" />
          <Button Content="Open logs folder" Command="{Binding OpenLogsFolderCommand}" Padding="12,8" Margin="0,0,8,0" />
          <Button Content="Open output folder" Command="{Binding OpenOutputFolderCommand}" Padding="12,8" />
        </StackPanel>

        <TextBlock Text="Progress" FontWeight="SemiBold" Margin="0,0,0,8" />
        <TextBlock Text="{Binding ProgressCount}" FontWeight="SemiBold" Margin="0,0,0,4" />
        <ProgressBar Height="10" Maximum="{Binding ProgressMaximum}" Value="{Binding ProgressValue}" Margin="0,0,0,8" />
        <TextBlock Text="Last completed:" Margin="0,0,0,2" />
        <TextBlock Text="{Binding LastFile}" TextWrapping="Wrap" Margin="0,0,0,12" />
      </StackPanel>
    </ScrollViewer>

    <GroupBox Grid.Row="1" Header="Log" Margin="0,12,0,0" BorderBrush="{DynamicResource GroupBoxBorderBrush}">
      <Grid>
        <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalAlignment="Stretch" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="12"
                 Background="{DynamicResource LogBackgroundBrush}" Foreground="{DynamicResource WindowForegroundBrush}" />
      </Grid>
    </GroupBox>
  </Grid>
</Window>
